{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "Service Health Overview",
      "type": "stat",
      "gridPos": { "h": 4, "w": 24, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "up{job=~\".*-service\"}",
          "legendFormat": "{{job}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "title": "CQRS Pipeline: Kafka Producer Rate",
      "description": "chat-service가 Kafka에 발행하는 이벤트 TPS",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "targets": [
        {
          "expr": "sum(rate(kafka_producer_topic_record_send_total{job=\"chat-service\"}[1m])) by (topic)",
          "legendFormat": "{{topic}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": { "drawStyle": "line", "fillOpacity": 15 }
        },
        "overrides": []
      }
    },
    {
      "title": "CQRS Pipeline: Kafka Consumer Rate",
      "description": "query/ai/notification 서비스의 Kafka 이벤트 소비 TPS",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "targets": [
        {
          "expr": "sum(rate(kafka_consumer_fetch_manager_records_consumed_total{job=~\".*-service\"}[1m])) by (job)",
          "legendFormat": "{{job}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": { "drawStyle": "line", "fillOpacity": 15 }
        },
        "overrides": []
      }
    },
    {
      "title": "Consumer Lag by Topic & Group",
      "description": "각 Consumer Group별 Kafka lag (높을수록 처리 지연)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "targets": [
        {
          "expr": "sum(kafka_consumer_fetch_manager_records_lag_max{job=~\".*-service\"}) by (job, topic)",
          "legendFormat": "{{job}} / {{topic}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "drawStyle": "line", "fillOpacity": 15, "lineWidth": 2 },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 100 },
              { "color": "red", "value": 1000 }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "title": "Event E2E Lag (발행 → 소비 지연시간)",
      "description": "Kafka 이벤트가 발행된 후 Consumer에서 처리 완료까지의 지연시간",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum(rate(messaging_event_end_to_end_lag_seconds_bucket[1m])) by (le, topic))",
          "legendFormat": "{{topic}} p99",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.50, sum(rate(messaging_event_end_to_end_lag_seconds_bucket[1m])) by (le, topic))",
          "legendFormat": "{{topic}} p50",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "drawStyle": "line", "fillOpacity": 10 }
        },
        "overrides": []
      }
    },
    {
      "title": "MongoDB Projection Duration (query-service)",
      "description": "query-service가 Kafka 이벤트를 받아 MongoDB에 프로젝션하는 데 걸리는 시간",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum(rate(messaging_event_projection_duration_seconds_bucket{job=\"query-service\"}[1m])) by (le))",
          "legendFormat": "p99",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(messaging_event_projection_duration_seconds_bucket{job=\"query-service\"}[1m])) by (le))",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.50, sum(rate(messaging_event_projection_duration_seconds_bucket{job=\"query-service\"}[1m])) by (le))",
          "legendFormat": "p50",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "drawStyle": "line", "fillOpacity": 10 }
        },
        "overrides": []
      }
    },
    {
      "title": "Kafka Producer Error Rate",
      "description": "Kafka 메시지 발행 실패율",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 },
      "targets": [
        {
          "expr": "sum(rate(kafka_producer_record_error_total{job=~\".*-service\"}[1m])) by (job)",
          "legendFormat": "{{job}} errors",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": { "drawStyle": "bars", "fillOpacity": 50 },
          "color": { "mode": "fixed", "fixedColor": "red" }
        },
        "overrides": []
      }
    },
    {
      "title": "Spam Detection Rate (ai-service)",
      "description": "AI 서비스의 스팸 탐지 이벤트 처리량",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 28 },
      "targets": [
        {
          "expr": "sum(rate(kafka_consumer_fetch_manager_records_consumed_total{job=\"ai-service\", topic=\"message.sent\"}[1m]))",
          "legendFormat": "messages analyzed",
          "refId": "A"
        },
        {
          "expr": "sum(rate(kafka_producer_topic_record_send_total{job=\"ai-service\", topic=\"message.spam-detected\"}[1m]))",
          "legendFormat": "spam detected",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": { "drawStyle": "line", "fillOpacity": 10 }
        },
        "overrides": []
      }
    },
    {
      "title": "Notification Delivery Rate",
      "description": "notification-service의 알림 이벤트 소비 및 처리량",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 28 },
      "targets": [
        {
          "expr": "sum(rate(kafka_consumer_fetch_manager_records_consumed_total{job=\"notification-service\"}[1m])) by (topic)",
          "legendFormat": "consumed: {{topic}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": { "drawStyle": "line", "fillOpacity": 10 }
        },
        "overrides": []
      }
    }
  ],
  "schemaVersion": 39,
  "tags": ["messaging-engine", "kafka", "cqrs"],
  "templating": { "list": [] },
  "time": { "from": "now-15m", "to": "now" },
